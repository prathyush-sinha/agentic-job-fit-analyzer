# Copy to .env and fill in. NEVER commit .env.

# Active embedding provider: "local" (default, free, no limits), "gemini", or "openai"
EMBEDDING_PROVIDER=local

# Local (default) — sentence-transformers on CPU, no API key needed
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Gemini — free key from https://aistudio.google.com/apikey (no billing).
# Used for the chat agent/judge; rate-limited for embeddings.
GOOGLE_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI (fallback — set EMBEDDING_PROVIDER=openai to use)
# Judge MUST differ from agent (avoids same-model self-grading bias)
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://jobfit:jobfit@localhost:5432/jobfit

# Retrieval ablation baseline flag (true = dense-only)
DENSE_ONLY=false
